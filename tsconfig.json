{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["mocha", "node"]
  },
  "include": ["tests/**/*.ts", "scripts/**/*.ts", "sdk/**/*.ts", "examples/**/*.ts"]
}

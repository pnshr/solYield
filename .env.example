ANCHOR_PROVIDER_URL=http://127.0.0.1:8899
ANCHOR_WALLET=~/.config/solana/id.json
SOLANA_CLUSTER=localnet

# Mainnet-fork testing.
# Use a paid or dedicated RPC for reliable --clone startup.
MAINNET_RPC_URL=https://api.mainnet-beta.solana.com
FORK_ADAPTER=all
FORK_LEDGER_PATH=.mainnet-fork-ledger
# Set to 1 to prefetch regular mainnet accounts into JSON fixtures and pass
# them to solana-test-validator with --account. This avoids public-RPC batch
# clone limits.
FORK_PREFETCH_ACCOUNTS=0
# Optional. With FORK_PREFETCH_ACCOUNTS=1 and no explicit value, the clone
# script uses the current mainnet slot from MAINNET_RPC_URL. Public examples may
# still need protocol-specific clock tuning for strict oracle freshness checks.
FORK_WARP_SLOT=500000000
FORK_USER_PUBKEY=
# Drift only: path to the official protocol-v2 v2.161.0 binary built from
# source (bash scripts/build-drift-v2161.sh). Required because the deployed
# mainnet Drift binary removed all user-facing instructions (wind-down at
# slot 410633860); see docs/MAINNET_FORK_TEST_RESULTS.md.
DRIFT_LOCAL_SO=.mainnet-fork-fixtures/drift-v2.161.0.so
FORK_USER_SOL_LAMPORTS=100000000000
FORK_USER_USDC_AMOUNT=1000000000
FORK_USER_SYRUP_AMOUNT=1000000000
MAINNET_FORK_TEST_TIMEOUT_MS=120000
# Diagnostic only. `doves-replay` attempts to replay recent mainnet Jupiter
# Doves oracle updates, but currently fails Doves InvalidSigner(6006) because
# keeper-signed Pyth Lazer payloads cannot be re-signed by the fork wallet.
JUPITER_ORACLE_REFRESH_MODE=
RUN_KAMINO_MAINNET_FORK=0
RUN_MARGINFI_MAINNET_FORK=0
RUN_JUPITER_MAINNET_FORK=0
RUN_MAPLE_MAINNET_FORK=0
RUN_DRIFT_MAINNET_FORK=0
RUN_KAMINO_INTEGRATION=0
RUN_MARGINFI_INTEGRATION=0
RUN_JUPITER_INTEGRATION=0
RUN_MAPLE_INTEGRATION=0
RUN_DRIFT_INTEGRATION=0

# Devnet registry deployment.
DEVNET_RPC_URL=https://api.devnet.solana.com
REGISTRY_AUTHORITY_KEYPAIR=
REGISTRY_PROGRAM_ID=HiLF1P7LguVyBbzMSN3hK4ErGxfxaS6TMPbR6R73Dtdn
# Where the deploy/verify scripts read & write the real devnet manifest.
DEVNET_MANIFEST_PATH=deployments/devnet/registry.json

# SDK example inputs.
DISPATCHER_PROGRAM_ID=FEKsMuAAp5Z6oxzsRkQLvHbMpvxJzVcV5JmGFD9KSC2A
ADAPTER_PROGRAM_ID=
SUPPORTED_MINT=
ADAPTER_VERSION=1
PROTOCOL_NAME=
METADATA_URI=
NEW_METADATA_URI=
NEW_GOVERNANCE_AUTHORITY=
ADAPTER_ENTRY=
ADAPTER_CONFIG=
ADAPTER_POSITION=
AMOUNT=
REMAINING_ACCOUNTS_JSON=[]
